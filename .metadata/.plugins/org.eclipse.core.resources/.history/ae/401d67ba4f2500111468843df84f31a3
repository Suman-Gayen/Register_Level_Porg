/*
 * System clock configured as follow
 * System Clock Source           = PLL(HSE)
 * SYSCLK(HZ)                    = 180000000
 * HCLK(HZ)                      = 180000000
 * AHB Prescaler                 = 1
 * APB1 Prescaler                = 4
 * APB2 Prescaler                = 2
 * MSE Frequency                 = 8000000
 * PLL_M                         = 4
 * PLL_N                         = 180
 * PLL_P                         = 2
 * VDD(V)                        = 3.3
 * Main regulator output voltage = scalel mode
 * Flash Latency (WS)            = 5
 *
 * */

#include "RCC_Config.h"
void SysClockConfig(void){

	#define PLL_M 4
	#define PLL_N 180
	#define PLL_P 0   // PLLP = 2

	/*---------- setups to follow ----------
	 * 1. Enable HSE clock
	 * 2. Enable power control clock
	 * 3. Set voltage scaling
	 * 4. Configure Flash latency
	 * 5. Configure AHB, APB1, APB2 prescalers
	 * 6. Configure PLL
	 * 7. Enable PLL and wait until ready
	 * 8. Select PLL as system clock
	 */

	// 1. Enable HSE and wait until ready
	RCC->CR |= (1<<16);          // HSEON
	while(!(RCC->CR & (1<<17))); // HSERDY

	// 2. Enable power controller clock
	RCC->APB1ENR |= (1<<28);

	// 3. Set voltage scaling (Scale 1 mode)
	PWR->CR |= (3<<14);

	// 4. Configure Flash latency and cache
	FLASH->ACR |= (1<<8) | (1<<9) | (1<<10) | (5<<0);

	// 5. Configure prescalers
	RCC->CFGR |= (0<<4);   // AHB prescaler = 1
	RCC->CFGR |= (5<<10);  // APB1 prescaler = 4
	RCC->CFGR |= (4<<13);  // APB2 prescaler = 2

	// 6. Configure PLL
	RCC->PLLCFGR |= (PLL_M<<0)  |
	                (PLL_N<<6)  |
	                (PLL_P<<16) |
	                (1<<22);     // HSE selected as PLL source

	// 7. Enable PLL and wait until ready
	RCC->CR |= (1<<24);          // PLLON
	while(!(RCC->CR & (1<<25))); // PLLRDY

	// 8. Select PLL as system clock
	RCC->CFGR |= (2<<0);         // Select PLL
	while(!(RCC->CFGR & (2<<2))); // Wait until PLL is system clock
}


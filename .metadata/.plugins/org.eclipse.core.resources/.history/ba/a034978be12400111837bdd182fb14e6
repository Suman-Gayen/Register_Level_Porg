
#include <stdint.h>
#include "RCC_Config.h"
#include "delay.h"

void UART2_Config(){
/*
	 * 1. Enable the UART clock and GPIO clock
	 * 2. Configure the UART pins for Alternate function
	 * 3. Enable the USART by writing the UE bit in USART_CR1 register to 1
	 * 4. Program the M bit in USART_CR1 to define the word length.
	 * 5. Select the desired baud rate using the USART_BRR register.
	 * 6. Enable the Tx/Rx by setting the TE and RE bits in USART_CR1 Register
	*/
//	 1. Enable the UART2 clock and GPIOA clock
	RCC->APB1ENR |= (1<<17);
	RCC->AHB1ENR |= (1<<0);
//	2. Configure the UART2 pins for Alternate function
	GPIOA->MODER |= (2<<4);  	// Enable PA2 as alternate function for Tx
	GPIOA->MODER |= (2<<6);;	// Enable PA3 as alternate function for Rx

	GPIOA->OSPEEDR |= (3<<4);	// SET port 4 as 11: High speed
	GPIOA->OSPEEDR |= (3<<6);	// SET port 6 as 11: High speed

//	15 14 13 12 | 11 10 9 8 set AF7 : 0111 as alternate mode
	GPIOA->AFR[0] |= (7<<8); // UART_Tx
	GPIOA->AFR[0] |= (7<<12); // UART_Rx

//	3. Enable the USART by writing the UE bit in USART_CR1 register to 1
	USART2->CR1 = 0x00; // Clear All
	USART2->CR1 |= (1<<13);

//	4. Program the M bit in USART_CR1 to define the word length.
	USART2->CR1 &= (~(1<<12)); // M = 0 : 1 Start bit, 8 Data bits, n Stop bit

//	5. Select the desired baud rate using the USART_BRR register.
	// calculation: Tx/Rx baud = fCK /(16 * USARTDIV)
	//						   = 45 000000 / (16 * 115200) = 24.4140625
	// now cal teh decimal value = 16*.4140625 =6.625= near the integer value of 7
	// so 7 is stored in Bits 3:0 DIV_Fraction[3:0]: fraction of USARTDIV and 24 is stored in Bits 15:4 DIV_Mantissa[15:4]: mantissa of USARTDIV
	USART2->BRR |= (7<<0) | (24<<4);

//	6. Enable the Tx/Rx by setting the TE and RE bits in USART_CR1 Register
	USART2->CR1 |= (1<<2); // ENABLE RE
	USART2->CR1 |= (1<<3); // ENABLE TE
}
void UART2_SendChar(uint8_t data){
	/*
	   1. Write the data to send in the USART_DR register (this clears the TXE bit). Repeat this
	      for each data to be transmitted in case of single buffer
	   2. After writing the last data into the USART_DR register, wait until TC=1. This indicates
		  that the transmission of the last frame is complete. This is required for instance when
		  the USART is disabled or enters the Halt mode to avoid corrupting the last
		  transmission
	*/
	USART2->DR = data; // load the data into data register
	while(!(USART2->SR & (1<<6))); // 1: Transmission is complete, wait for TC to set... this indicates that the data has been transmitted
}
void UART2_SendString(char *string){
	while (*string) UART2_SendChar(*string++);
}
void UART2_getChar(void){
	while(!(USART2->SR & (1<<5)));
	uint8_t temp = USART2->DR;
	return temp;
}
int main(void)
{
	SysClockConfig();
	TIM6Config();
	UART2_Config();

	while(1){
//		UART2_SendString("Hello \n");
//		delay_us(1000);

		// Receiving the data
		uint8_t data = UART2_getChar();
		UART2_SendChar(data);
	}

}

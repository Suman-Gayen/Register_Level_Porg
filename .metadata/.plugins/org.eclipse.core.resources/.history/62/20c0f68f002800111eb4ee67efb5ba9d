void SPI_Config(void){
	/*
	 * 1. Enable SPI clock
	 * 2. Configure the Control Register 1
	 * 3. Configure the Control Register 2
	*/
	RCC->APB2ENR |= (1<<12);
	SPI1->CR1 |= (1<<0) | (1<<1); // Bit 0 CPHA: Clock phase & Bit1 CPOL: Clock polarity
	SPI1->CR2 |= (1<<2);		  // Master mode
	SPI1->CR1 |= (3<<3);          // BR[2:0] = 011: fPCLK/16, PCLK2 = 80MHz, SPI CLK = 5MHz
	SPI1->CR1 &= ~(1<<7);		  // LSBFIRST = 0, MSB first
	SPI1->CR1 |= (1<<8) | (1<<9); // SSM=1, SSI=1 => Software slave management
	SPI1->CR1 &= ~(1<<10); 		  // RXONLY = 0, Full-Duplex
	SPI1->CR1 &= ~(1<<11);		  // DFF=0, 8 bit data
	SPI1->CR2 = 0;
}
void GPIO_Config(void){
	RCC->AHB1ENR |= (1<<0); // Enable GPIOA
	GPIOA->MODER |= (2<<10) | (2<<12) | (2<<14) | (1<<8); // PA5,PA6,PA7 as alternate func mode and PA4 as Output mode
	GPIOA->OTYPER &= ~((1<<4) | (1<<5) | (1<<6) | (1<<7)); // 0: Output push-pull (reset state) mode on PA4,PA5,PA6,PA7
	GPIOA->OSPEEDR |= (3<<10) | (3<<12) | (3<<14) | (3<<8); // 11: High speed mode set on PA4,PA5,PA6,PA7
	GPIOA->AFR[0] |= (5<<16) | (5<<20) | (5<<24) | (5<<28); // 0101: AF5
}
void SPI_Enable(void){
	SPI1->CR1 |= (1<<6);
}
void SPI_Desable(void){
	SPI1->CR1 &= ~(1<<6);
}
void CS_Enable (void)
{
	GPIOA->BSRR |= (1<<4)<<16; // 4 + 16 = 20 → reset bit position for pin 4.
}

void CS_Disable (void)
{
	GPIOA->BSRR |= (1<<4);
}

void SPI_Transmit (uint8_t *data, int size)
{

	/************** STEPS TO FOLLOW *****************
	1. Wait for the TXE bit to set in the Status Register
	2. Write the data to the Data Register
	3. After the data has been transmitted, wait for the BSY bit to reset in Status Register
	4. Clear the Overrun flag by reading DR and SR
	************************************************/

	int i=0;
	while (i<size)
	{
	   while (!((SPI1->SR)&(1<<1))) {};  // wait for TXE bit to set -> This will indicate that the buffer is empty
	   SPI1->DR = data[i];  // load the data into the Data Register
	   i++;
	}


/*During discontinuous communications, there is a 2 APB clock period delay between the
write operation to the SPI_DR register and BSY bit setting. As a consequence it is
mandatory to wait first until TXE is set and then until BSY is cleared after writing the last
data.
*/
	while (!((SPI1->SR)&(1<<1))) {};  // wait for TXE bit to set -> This will indicate that the buffer is empty
	while (((SPI1->SR)&(1<<7))) {};  // wait for BSY bit to Reset -> This will indicate that SPI is not busy in communication


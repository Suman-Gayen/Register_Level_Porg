
#include "I2C.h"

void I2C_Config(void){

	RCC->AHB1ENR |= (1<<1);  //	Configure system clock.
	RCC->APB1ENR |= (1<<21); //	Enable GPIO and I²C clocks.
	GPIOB->MODER  |= (2<<16) | (2<<18);//	Configure I²C GPIO pins. | SCL=PB8 and SDA=PB9 set as alternate function 1 0
	GPIOB->OTYPER |= (1<<8); // SCL set as (1) Output open-drain
	GPIOB->OTYPER |= (1<<9); // SDA set as (1) Output open-drain
//	GPIOB set as (11) high speed
	GPIOB->OSPEEDR |= (3<<16); // SCL
	GPIOB->OSPEEDR |= (3<<18); // SDA
//	GPIOB port set as pull-up (01) register
	GPIOB->PUPDR |= (1<<16);
	GPIOB->PUPDR |= (1<<18);
//	set alternate mode for SCL AND SDA | 0100: AF4
//	7 6 5 4 | 3 2 1 0
	GPIOB->AFR[1] |= (4<<0) | (4<<4); // AF4 for PB8 and AF4 for PB9

	I2C1->CR1 |= (1<<15); // RESET I2C clock
	I2C1->CR1 &= (~(1<<15));
	I2C1->CR2 |= (45<<0); // SET APB1 frequency at 45 mHZ
	// configure the clock control register
	/* Tr(SCL) = 1000 | Tw(SCLH) = 4000 | T(pclk1) = 1/45mHZ = 22.22 ====> From datasheet
	 * CCR = ( Tr(SCL) + Tw(SCLH) )/T(pclk1) = (1000+4000)/22.22 = 225
	 * */
	I2C1->CCR   |= (225<<0);
	/* Configure RISE Time register =======
	 * TRISE = Tr(SCL)/T(pclk1) +1;
	 * 		 = 1000/22.22 +1 = 46
	 * */
	I2C1->TRISE |= 46;
	I2C1->CR1   |= (1<<0); // Program I2C1 register to enable the peripheral
}

void I2C_Start(void){
	I2C1->CR1 |= (1<<10);		  // the Acknowlegment by setting the ACK
	I2C1->CR1 |= (1<<8);          // Send the start condition
	while(!(I2C1->SR1 & (1<<0))); // wait for the SB (bit 0 in SR1) to set. This indicate start condition is generated
}
void I2C_Write(uint8_t data){
	while(!(I2C1->SR1 & (1<<7))); // wait for Tx bit to set | to indicates that the DR is empty
	I2C1->DR = data;			  // send the data to the DR register
	while(!(I2C1->SR1 & (1<<2))); // wait for BTF: Byte transfer finished bit to set | to indicates the end of last data transmission
}

void I2C_address(uint8_t address){
	I2C1->DR = address;			  		  // send the slave address to the DR register
	while(!(I2C1->SR1 & (1<<1)));		  // wait for ADDR bit to set
//	uint8_t temp = I2C1->SR1 | I2C1->SR2; // read SR1 and SR2 to clear the ADDR bit
	I2C1->SR1 &= (~(1<<1));
}
void I2C_Stop(void){
	I2C1->CR1 |= (1<<9);                  // STOP I2C
}
void I2C_WriteMulti(uint8_t *data, uint8_t size){
	while(!(I2C1->SR1 & (1<<7)));         // wait for TxE bit to set | this indicate the DR register was empty
	while(size){
		while(!(I2C1->SR1 & (1<<7)));          // wait for TxE bit to set
		I2C1->DR = (volatile uint32_t)*data++; // send data
		size--;
	}
	while(!(I2C1->SR1 & (1<<2)));              // check every time, wait for BTF to set | this indicate the end of last data transmission
}

void I2C_Read(uint8_t address, uint8_t *buffer, uint8_t size){
	/**** STEPS FOLLOWED  ************
	1. If only 1 BYTE needs to be Read
		a) Write the slave Address, and wait for the ADDR bit (bit 1 in SR1) to be set
		b) the Acknowledge disable is made during EV6 (before ADDR flag is cleared) and the STOP condition generation is made after EV6
		c) Wait for the RXNE (Receive Buffer not Empty) bit to set
		d) Read the data from the DR

	2. If Multiple BYTES needs to be read
	    a) Write the slave Address, and wait for the ADDR bit (bit 1 in SR1) to be set
		b) Clear the ADDR bit by reading the SR1 and SR2 Registers
		c) Wait for the RXNE (Receive buffer not empty) bit to set
		d) Read the data from the DR
		e) Generate the Acknowlegment by setting the ACK (bit 10 in SR1)
		f) To generate the nonacknowledge pulse after the last received data byte, the ACK bit must be cleared just after reading the
			 second last data byte (after second last RxNE event)
		g) In order to generate the Stop/Restart condition, software must set the STOP/START bit
		   after reading the second last data byte (after the second last RxNE event)
	*/

	int remaining = size;

//	 ===================== step 1 =============================== //
	if (size == 1){
		// step 1-a =====
		I2C1->DR |= address;                  // send the address
		while(!(I2C1->SR1 & (1<<1)));         // wait for the ADDR bit to set
		// step 1-b =====
		I2C1->CR1 &= ~(1<<10);                // CLEAR the ACK bit
		uint8_t temp = I2C1->SR1 | I2C1->SR2; // Read SR1 and SR2 to clear the ADDR bit.... EV6 condition
		I2C1->CR1 |= (1<<9);                  // Stop I2C
		// step 1-c =====
		while(!(I2C1->SR1 & (1<<6)));         // wait for RxNE to set
		// step 1-d =====
		buffer[size-remaining] = I2C1->DR;    // Read the data from the DR
	}
	//	 ===================== step 2 =============================== //
	else{
		// step 2-a =====
		I2C1->DR |= address;                  // send the address
		while(!(I2C1->SR1 & (1<<1)));         // wait for the ADDR bit to set
		// step 2-b =====
		uint8_t temp = I2C1->SR1 | I2C1->SR2; // Read SR1 and SR2 to clear the ADDR bit.... EV6 condition

		while(remaining>2){
			// step 2-c =====
			while(!(I2C1->SR1 & (1<<6)));	  // wait for RxNE to set
			// step 2-d =====
			buffer[size-remaining] = I2C1->DR;// copy the data into the buffer
			// step 2-e =====
			I2C1->CR1 |= (1<<10); 			  // the Acknowlegment by setting the ACK

			remaining--;
		}
//		reading the second last data byte
		while(!(I2C1->SR1 & (1<<6))); 		  // wait for RxNE to set
		buffer[size-remaining] = I2C1->DR;    // copy the data into the buffer

		// step 2-f =====
		I2C1->CR1 &= ~(1<<10); 			 	  // clear the ACK bit
		// step 2-g =====
		I2C1->CR1 |= (1<<9); 				  // STOP I2C
		remaining--;
	}
	// Read the last byte
	while(!(I2C1->SR1 & (1<<6)));             // wait for RxNE to set
	buffer[size-remaining] = I2C1->DR;        // copy the data into the buffer
}




















